# Copy to ".env.local" and adjust values (never commit .env.local).

# Backend REST API base URL (no trailing slash). Used only on the server
# (Server Components, Server Actions, Route Handlers) — safe for private keys.
API_BASE_URL=http://127.0.0.1:8000/api

# Only if the browser must call your API directly (exposes the value in the bundle).
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api

# Prefix for product image filenames returned by the API (imageUrl). No trailing slash.
# NEXT_PUBLIC_MEDIA_BASE_URL=http://127.0.0.1:8000/uploads
